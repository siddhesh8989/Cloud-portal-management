@app.route("/admin/delete-resource/<resource_id>", methods=["POST"])
@admin_required
def delete_resource(resource_id):
    storage.delete_resource(resource_id)
    flash("Resource deleted.", "success")
    return redirect(url_for("admin_panel"))


@app.route("/predict-demand")
@login_required
def predict_demand_endpoint():
    resources = storage.get_all_resources()
    result = predict_demand(resources)
    return jsonify(result)


OPTIMIZER_PROFILES = {
    "low":    {"cpu": 1, "ram": 2,  "storage": 20},
    "medium": {"cpu": 2, "ram": 4,  "storage": 50},
    "high":   {"cpu": 4, "ram": 8,  "storage": 100},
}

POLICY_LIMITS = {"cpu": 4, "ram": 8, "storage": 100}


@app.route("/optimizer", methods=["GET", "POST"])
@login_required
def optimizer():
    result = None
    selected_level = None
    warnings = []

    if request.method == "POST":
        level = request.form.get("workload_level", "").lower()
        if level in OPTIMIZER_PROFILES:
            selected_level = level
            profile = OPTIMIZER_PROFILES[level]
            result = profile.copy()

            if profile["cpu"] > POLICY_LIMITS["cpu"]:
                warnings.append(f"CPU ({profile['cpu']} cores) exceeds policy limit of {POLICY_LIMITS['cpu']} cores.")
            if profile["ram"] > POLICY_LIMITS["ram"]:
                warnings.append(f"RAM ({profile['ram']} GB) exceeds policy limit of {POLICY_LIMITS['ram']} GB.")
            if profile["storage"] > POLICY_LIMITS["storage"]:
                warnings.append(f"Storage ({profile['storage']} GB) exceeds policy limit of {POLICY_LIMITS['storage']} GB.")
        else:
            flash("Please select a valid workload level.", "error")

    return render_template("optimizer.html", result=result, selected_level=selected_level, warnings=warnings)


if __name__ == "__main__":
    port = int(os.environ.get("PORT", 5000))
    app.run(host="0.0.0.0", port=port, debug=False)
